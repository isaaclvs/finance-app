<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <title><%= t("app.name") %> - <%= yield(:title) || t("devise.views.sessions.new.title") %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50 dark:bg-gray-900">
    <!-- Flash messages -->
    <div id="flash" class="fixed top-4 right-4 z-50">
      <% if notice.present? %>
        <div class="bg-green-100 dark:bg-green-900 border border-green-400 dark:border-green-600 text-green-700 dark:text-green-200 px-4 py-3 rounded mb-4 transition-theme" role="alert">
          <span class="block sm:inline"><%= notice %></span>
        </div>
      <% end %>
      
      <% if alert.present? %>
        <div class="bg-red-100 dark:bg-red-900 border border-red-400 dark:border-red-600 text-red-700 dark:text-red-200 px-4 py-3 rounded mb-4 transition-theme" role="alert">
          <span class="block sm:inline"><%= alert %></span>
        </div>
      <% end %>
    </div>

    <!-- Theme toggle button -->
    <div class="fixed top-4 left-4 z-50">
      <button type="button"
              data-controller="theme"
              data-action="click->theme#toggle"
              class="p-2 text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-white rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 transition-all">
        <svg data-theme-target="icon" class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
          <!-- Icon will be inserted by Stimulus controller -->
        </svg>
      </button>
    </div>
    <div class="fixed top-4 right-4 z-50 flex items-center gap-2 text-xs text-gray-500 dark:text-gray-400">
      <span class="uppercase"><%= t("app.nav.language") %></span>
      <%= link_to t("app.nav.locale.en"), url_for(locale: :en),
          class: "#{I18n.locale.to_s == 'en' ? 'text-gray-900 dark:text-white font-semibold' : 'hover:text-gray-700 dark:hover:text-gray-200'}" %>
      <%= link_to t("app.nav.locale.pt_br"), url_for(locale: :'pt-BR'),
          class: "#{I18n.locale.to_s == 'pt-BR' ? 'text-gray-900 dark:text-white font-semibold' : 'hover:text-gray-700 dark:hover:text-gray-200'}" %>
    </div>

    <main class="min-h-screen">
      <%= yield %>
    </main>
  </body>
</html>
