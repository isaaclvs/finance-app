<div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
  <div class="bg-white dark:bg-gray-800 shadow sm:rounded-lg p-6">
    <h1 class="text-2xl font-semibold text-gray-900 dark:text-white"><%= t("transaction_imports.preview.title") %></h1>

    <div class="mt-4 grid grid-cols-2 md:grid-cols-3 gap-3 text-sm">
      <p><strong><%= t("transaction_imports.preview.summary.total") %>:</strong> <%= @preview[:summary][:total_rows] %></p>
      <p><strong><%= t("transaction_imports.preview.summary.valid") %>:</strong> <%= @preview[:summary][:valid_rows] %></p>
      <p><strong><%= t("transaction_imports.preview.summary.invalid") %>:</strong> <%= @preview[:summary][:invalid_rows] %></p>
      <p><strong><%= t("transaction_imports.preview.summary.duplicate_file") %>:</strong> <%= @preview[:summary][:duplicate_in_file_count] %></p>
      <p><strong><%= t("transaction_imports.preview.summary.duplicate_existing") %>:</strong> <%= @preview[:summary][:duplicate_existing_count] %></p>
      <p><strong><%= t("transaction_imports.preview.summary.importable") %>:</strong> <%= @preview[:summary][:importable_count] %></p>
    </div>

    <% if @preview[:row_errors].any? %>
      <div class="mt-6 rounded-md bg-red-50 dark:bg-red-900/20 p-4">
        <h2 class="text-sm font-medium text-red-800 dark:text-red-200"><%= t("transaction_imports.preview.invalid_rows") %></h2>
        <ul class="mt-2 list-disc pl-5 text-sm text-red-700 dark:text-red-300">
          <% @preview[:row_errors].each do |error| %>
            <li>
              <%= t("transaction_imports.preview.line", line: error[:line]) %>:
              <%= error[:errors].join(", ") %>
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="mt-6 overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-300 dark:divide-gray-700">
        <thead class="bg-gray-50 dark:bg-gray-700">
          <tr>
            <th class="px-3 py-2 text-left text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-300"><%= t("transaction_imports.preview.columns.date") %></th>
            <th class="px-3 py-2 text-left text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-300"><%= t("transaction_imports.preview.columns.description") %></th>
            <th class="px-3 py-2 text-left text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-300"><%= t("transaction_imports.preview.columns.category") %></th>
            <th class="px-3 py-2 text-left text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-300"><%= t("transaction_imports.preview.columns.type") %></th>
            <th class="px-3 py-2 text-left text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-300"><%= t("transaction_imports.preview.columns.amount") %></th>
            <th class="px-3 py-2 text-left text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-300"><%= t("transaction_imports.preview.columns.status") %></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
          <% @preview[:rows].each do |row| %>
            <% status_label = if row[:importable]
                                t("transaction_imports.preview.status.importable")
                              elsif row[:duplicate_in_file]
                                t("transaction_imports.preview.status.duplicate_file")
                              else
                                t("transaction_imports.preview.status.duplicate_existing")
                              end %>
            <tr>
              <td class="px-3 py-2 text-sm text-gray-800 dark:text-gray-100"><%= l(row[:date]) %></td>
              <td class="px-3 py-2 text-sm text-gray-800 dark:text-gray-100"><%= row[:description].presence || "-" %></td>
              <td class="px-3 py-2 text-sm text-gray-800 dark:text-gray-100"><%= row[:category_name] %></td>
              <td class="px-3 py-2 text-sm text-gray-800 dark:text-gray-100"><%= row[:transaction_type] %></td>
              <td class="px-3 py-2 text-sm text-gray-800 dark:text-gray-100"><%= number_to_currency(row[:amount]) %></td>
              <td class="px-3 py-2 text-sm text-gray-800 dark:text-gray-100"><%= status_label %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="mt-6 flex items-center gap-3">
      <%= button_to t("transaction_imports.preview.confirm_button"), transaction_imports_path, method: :post, class: "inline-flex items-center rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700" %>
      <%= link_to t("transaction_imports.preview.back"), new_transaction_import_path, class: "text-sm text-gray-600 dark:text-gray-300 hover:underline" %>
    </div>
  </div>
</div>
